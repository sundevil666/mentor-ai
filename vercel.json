{
  "buildCommand": "npm run build:vercel",
  "outputDirectory": "apps/pwa/dist/pwa",
  "installCommand": "npm install --ignore-scripts",
  "framework": null,
  "routes": [
    {
      "src": "^/app-update\\.json$",
      "headers": {
        "Cache-Control": "no-store, max-age=0"
      },
      "continue": true
    },
    {
      "src": "^/sw\\.js$",
      "headers": {
        "Cache-Control": "no-cache, max-age=0, must-revalidate"
      },
      "continue": true
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "^(?:/(.*))$",
      "dest": "/index.html"
    }
  ]
}
